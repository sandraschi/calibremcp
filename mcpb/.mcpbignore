# MCP Central Docs — MCPB_PACKAGING_STANDARDS.md: no bundled deps; glama stays repo-only

# Never ship lockfiles or project metadata inside .mcpb (use repo / uv sync separately)
pyproject.toml
uv.lock
poetry.lock
Pipfile
Pipfile.lock
requirements.txt

# Glama discovery file lives at repo root only — not inside the Claude Desktop bundle
glama.json

# Build output nested under mcpb/
dist/

# Python cache
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Dev
.pytest_cache/
.coverage
htmlcov/
.tox/
.vscode/
.idea/
*.log

# OS
.DS_Store
Thumbs.db

# Archives (if any)
*.zip
*.tar.gz
